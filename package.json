{
    "name": "daily-sync",
    "version": "1.0.0",
    "description": "Provider-based backup library with GFS retention for WebDAV, FTP, and local disk targets",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx src/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "license": "MIT",
    "engines": {
        "node": ">=22.0.0"
    },
    "dependencies": {
        "basic-ftp": "^5.0.5",
        "joi": "^18.1.1",
        "node-cron": "^3.0.3",
        "nodemailer": "^6.9.16",
        "pino": "^9.6.0",
        "webdav": "^5.8.0"
    },
    "devDependencies": {
        "@types/node": "^20.17.0",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^6.4.17",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
